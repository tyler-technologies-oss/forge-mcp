import type {
  BusyIndicatorComponent,
  ConfirmationDialogComponent,
  QuantityFieldComponent,
  ResponsiveToolbarComponent,
  ThemeToggleComponent,
  UserProfileComponent,
  Event,
  ProfileLinkComponent,
} from "../index.d.ts";

type BaseProps = {
  /** Content added between the opening and closing tags of the element */
  children?: JSX.Element;
  /** Used for declaratively styling one or more elements using CSS (Cascading Stylesheets) */
  class?: string;
  /** Takes an object where the key is the class name(s) and the value is a boolean expression. When true, the class is applied, and when false, it is removed. */
  classList?: Record<string, boolean | undefined>;
  /** Specifies the text direction of the element. */
  dir?: "ltr" | "rtl";
  /** Contains a space-separated list of the part names of the element that should be exposed on the host element. */
  exportparts?: string;
  /** Specifies whether the element should be hidden. */
  hidden?: boolean | string;
  /** A unique identifier for the element. */
  id?: string;
  /** Sets the HTML or XML markup contained within the element. */
  innerHTML?: string;
  /** Specifies the language of the element. */
  lang?: string;
  /** Contains a space-separated list of the part names of the element. Part names allows CSS to select and style specific elements in a shadow tree via the ::part pseudo-element. */
  part?: string;
  /** Use the ref attribute with a variable to assign a DOM element to the variable once the element is rendered. */
  ref?: unknown | ((e: unknown) => void);
  /** Adds a reference for a custom element slot */
  slot?: string;
  /** Prop for setting inline styles */
  style?: JSX.CSSProperties;
  /** Overrides the default Tab button behavior. Avoid using values other than -1 and 0. */
  tabIndex?: number;
  /** Sets the text content of the element */
  textContent?: string;
  /** Specifies the tooltip text for the element. */
  title?: string;
  /** Passing 'no' excludes the element content from being translated. */
  translate?: "yes" | "no";
};

type BaseEvents = {};

type BusyIndicatorComponentProps = {
  /** Indicates whether the busy indicator is open. */
  open?: BusyIndicatorComponent["open"];
  /** Whether the busy indicator is fullscreen or inline. */
  mode?: BusyIndicatorComponent["mode"];
  /** The title text to display. */
  "title-text"?: BusyIndicatorComponent["titleText"];
  /** The heading level for the title. */
  "heading-level"?: BusyIndicatorComponent["headingLevel"];
  /** The message to display. */
  message?: BusyIndicatorComponent["message"];
  /** The accessible label for dialog. */
  label?: BusyIndicatorComponent["label"];
  /** The accessible description for dialog. */
  description?: BusyIndicatorComponent["description"];
  /** Indicates whether the cancel button is displayed. */
  cancelable?: BusyIndicatorComponent["cancelable"];
  /** The variant of the busy indicator.
- `spinner` (default): displays a spinner.
- `progress`: displays a progress bar.
- `message-only`: No progress indicator is displayed. */
  variant?: BusyIndicatorComponent["variant"];
  /** Indicates whether the loading indicator is determinate. */
  determinate?: BusyIndicatorComponent["determinate"];
  /** The progress amount for the progress bar. */
  progress?: BusyIndicatorComponent["progress"];
  /** The buffer amount for the progress bar. */
  buffer?: BusyIndicatorComponent["buffer"];
  /** Indicates whether the busy indicator surface should be transparent (no background or elevation). */
  transparent?: BusyIndicatorComponent["transparent"];

  /** Fired when the cancel button is clicked. */
  "on:forge-busy-indicator-cancel"?: (e: CustomEvent<CustomEvent<void>>) => void;
};

type ConfirmationDialogComponentProps = {
  /** Indicates whether the confirmation dialog is open */
  open?: ConfirmationDialogComponent["open"];
  /** The accessible label for dialog */
  label?: ConfirmationDialogComponent["label"];
  /** The accessible description for dialog */
  description?: ConfirmationDialogComponent["description"];
  /** Indicates whether the confirmation dialog is in a busy state */
  "is-busy"?: ConfirmationDialogComponent["isBusy"];
  /** ARIA label for the the busy indicator when loading */
  "busy-label"?: ConfirmationDialogComponent["busyLabel"];

  /** Fired when an action button is clicked. Will contain `false` if the secondary button is clicked, `true` if the primary button is clicked. */
  "on:forge-confirmation-dialog-action"?: (e: CustomEvent<CustomEvent<ConfirmationDialogActionEventData>>) => void;
};

type QuantityFieldComponentProps = {
  /** Indicates whether the field is invalid. */
  invalid?: QuantityFieldComponent["invalid"];
  /** Indicates whether the field is required. */
  required?: QuantityFieldComponent["required"];
  /** The accessible label for the decrement button. */
  "decrement-label"?: QuantityFieldComponent["decrementLabel"];
  /** The accessible label for the increment button. */
  "increment-label"?: QuantityFieldComponent["incrementLabel"];
};

type ResponsiveToolbarComponentProps = {
  /** Hides the divider */
  "no-border"?: ResponsiveToolbarComponent["noBorder"];
  /** Controls whether a bottom divider (default) or top divider (true) is used. */
  inverted?: ResponsiveToolbarComponent["inverted"];
  /** Controls the delay in milliseconds to throttle resize events */
  "resize-delay"?: ResponsiveToolbarComponent["resizeDelay"];

  /** Dispatched when the overflow state changes. */
  "on:forge-responsive-toolbar-update"?: (e: CustomEvent<CustomEvent<ResponsiveToolbarUpdateEventData>>) => void;
};

type ThemeToggleComponentProps = {
  /** Fired when the theme is changed */
  "on:forge-theme-toggle-update"?: (e: CustomEvent<CustomEvent<ThemeToggleThemeEventData>>) => void;
};

type UserProfileComponentProps = {
  /** The full name of the user */
  "full-name"?: UserProfileComponent["fullName"];
  /** The email address of the user */
  email?: UserProfileComponent["email"];
  /** ARIA label for the user profile avatar button */
  "button-label"?: UserProfileComponent["buttonLabel"];
  /** Indicates whether the theme toggle is visible */
  "theme-toggle"?: UserProfileComponent["themeToggle"];

  /** Fired when the sign out button is clicked. */
  "on:forge-user-profile-sign-out"?: (e: CustomEvent<Event>) => void;
};

type ProfileLinkComponentProps = {};

export type CustomElements = {
  /**
   *
   * ---
   *
   *
   * ### **Events:**
   *  - **forge-busy-indicator-cancel** - Fired when the cancel button is clicked.
   *
   * ### **Slots:**
   *  - **title** - The title text to display.
   * - **message** - The message to display.
   * - **cancel-text** - The text for the cancel button.
   */
  "forge-busy-indicator": Partial<BusyIndicatorComponentProps & BaseProps & BaseEvents>;

  /**
   *
   * ---
   *
   *
   * ### **Events:**
   *  - **forge-confirmation-dialog-action** - Fired when an action button is clicked. Will contain `false` if the secondary button is clicked, `true` if the primary button is clicked.
   *
   * ### **Slots:**
   *  - **title** - The title of the dialog
   * - **message** - The dialog message
   * - **secondary-button-text** - The text used in the secondary action button
   * - **primary-button-text** - The text used in the primary action button
   */
  "forge-confirmation-dialog": Partial<ConfirmationDialogComponentProps & BaseProps & BaseEvents>;

  /**
   *
   * ---
   *
   *
   * ### **Slots:**
   *  - _default_ - Reserved for the `<input>` element.
   * - **label** - The label for the field.
   * - **decrement-button** - The decrement button.
   * - **decrement-icon** - The icon for the decrement button.
   * - **increment-button** - The increment button.
   * - **increment-icon** - The icon for the increment button.
   * - **support-text** - The support text for the field.
   */
  "forge-quantity-field": Partial<QuantityFieldComponentProps & BaseProps & BaseEvents>;

  /**
   *
   * ---
   *
   *
   * ### **Events:**
   *  - **forge-responsive-toolbar-update** - Dispatched when the overflow state changes.
   *
   * ### **Slots:**
   *  - **before-start** - Maps to the toolbar before-start slot
   * - **start** - Maps to the toolbar start slot
   * - **end-large** - The content you want to render at larger sizes in the toolbar end slot
   * - **end-small** - The content you want to render at smaller sizes in the toolbar end slot
   * - **after-end** - Maps to the toolbar after-end slot
   */
  "forge-responsive-toolbar": Partial<ResponsiveToolbarComponentProps & BaseProps & BaseEvents>;

  /**
   *
   * ---
   *
   *
   * ### **Events:**
   *  - **forge-theme-toggle-update** - Fired when the theme is changed
   *
   * ### **Methods:**
   *  - **setTheme(value: _ThemeToggleTheme_): _void_** - Sets the current theme.
   *
   * ### **Slots:**
   *  - **title** - The title shown above the toggle buttons
   */
  "forge-theme-toggle": Partial<ThemeToggleComponentProps & BaseProps & BaseEvents>;

  /**
   *
   * ---
   *
   *
   * ### **Events:**
   *  - **forge-user-profile-sign-out** - Fired when the sign out button is clicked.
   *
   * ### **Methods:**
   *  - **setTheme(value: _ThemeToggleTheme_): _void_** - Sets the theme for the theme toggle.
   *
   * ### **Slots:**
   *  - **link** - Slot for additional profile navigation links
   * - **sign-out-button-text** - Slot for the sign out button text
   */
  "forge-user-profile": Partial<UserProfileComponentProps & BaseProps & BaseEvents>;

  /**
   *
   * ---
   *
   *
   * ### **Slots:**
   *  - **icon** - The icon to display in the profile link.
   * - _default_ - The `<a>` element for the link.
   */
  "forge-profile-link": Partial<ProfileLinkComponentProps & BaseProps & BaseEvents>;
};

declare namespace svelteHTML {
  // eslint-disable-next-line @typescript-eslint/no-empty-interface
  interface IntrinsicElements extends CustomElements {}
}
